pipeline {
    agent any

    environment {
        // REPLACE this with your actual Docker Hub username in the Jenkins UI or here
        DOCKER_HUB_USER_RAW = "YOUR_DOCKERHUB_NAMESPACE" 
        DOCKER_CONTEXT = 'default'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Push Images') {
            steps {
                script {
                    def dockerUser = env.DOCKER_HUB_USER_RAW.toLowerCase()
                    def pytestImage = "${dockerUser}/petstore-pytest:${env.BUILD_NUMBER}"
                    def locustImage = "${dockerUser}/petstore-locust:${env.BUILD_NUMBER}"
                    def pytestLatest = "${dockerUser}/petstore-pytest:latest"
                    def locustLatest = "${dockerUser}/petstore-locust:latest"

                    docker.withRegistry('https://index.docker.io/v1/', 'docker-registry-credentials') {
                        
                        echo "Building Pytest image..."
                        def pytestImg = docker.build("${pytestImage}", "-f infrastructure/docker/Dockerfile.pytest .")
                        pytestImg.tag("latest")

                        echo "Building Locust image..."
                        def locustImg = docker.build("${locustImage}", "-f infrastructure/docker/Dockerfile.locust .")
                        locustImg.tag("latest")

                        echo "Pushing images (Build Tag & Latest)..."
                        pytestImg.push()
                        pytestImg.push("latest")
                        locustImg.push()
                        locustImg.push("latest")
                    }
                    
                    env.FINAL_PYTEST_IMAGE = pytestImage
                    env.FINAL_LOCUST_IMAGE = locustImage
                }
            }
        }

        stage('API Tests (Pytest)') {
            steps {
                script {
                    sh "mkdir -p ${WORKSPACE}/reports"
                    sh "docker run --rm -v ${WORKSPACE}/reports:/app/reports ${env.FINAL_PYTEST_IMAGE}"
                }
            }
            post {
                always {
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports',
                        reportFiles: 'report.html',
                        reportName: 'Pytest API Report',
                        reportTitles: 'Petstore API Test Execution'
                    ])
                }
            }
        }

        stage('Deploy Performance Infrastructure (K8s)') {
            steps {
                script {
                    sh "kubectl apply -f infrastructure/k8s/locust.yaml"
                    sh "kubectl set image deployment/locust-master locust-master=${env.FINAL_LOCUST_IMAGE}"
                    sh "kubectl set image deployment/locust-worker locust-worker=${env.FINAL_LOCUST_IMAGE}"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
