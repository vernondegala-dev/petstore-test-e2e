pipeline {
    agent any

    environment {
        // IMPORTANT: Change this to your actual Docker Hub username.
        // It will be automatically converted to lowercase by the script below.
        DOCKER_HUB_USER_RAW = "YOUR_DOCKERHUB_NAMESPACE" 
        
        // Forces Docker to use the default context (local Unix socket)
        DOCKER_CONTEXT = 'default'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Push Images') {
            steps {
                script {
                    // Dynamically evaluate your actual account username
                    def pytestImageName = "${DOCKER_REGISTRY}/petstore-pytest:${env.BUILD_NUMBER}"
                    def locustImageName = "${DOCKER_REGISTRY}/petstore-locust:${env.BUILD_NUMBER}"

                    docker.withRegistry('https://index.docker.io/v1/', 'docker-registry-credentials') {

                        echo "Building Pytest image: ${pytestImageName}"
                        sh "docker build -t ${pytestImageName} -f infrastructure/docker/Dockerfile.pytest ."

                        echo "Building Locust image: ${locustImageName}"
                        sh "docker build -t ${locustImageName} -f infrastructure/docker/Dockerfile.locust ."

                        echo "Pushing images to Docker Hub..."
                        sh "docker push ${pytestImageName}"
                        sh "docker push ${locustImageName}"
                    }
                }
            }
        }

        stage('API Tests (Pytest)') {
            steps {
                script {
                    // Reconstruct the exact image tag built and pushed in the previous stage
                    def pytestImageRun = "${DOCKER_REGISTRY}/petstore-pytest:${env.BUILD_NUMBER}"

                    echo "Running containerized tests using image: ${pytestImageRun}"

                    // 1. Pre-create the directory cleanly
                    sh "mkdir -p ${WORKSPACE}/reports"

                    // 2. Execute the verified dynamic image name instead of letting it default to null
                    sh "docker run --rm -v ${WORKSPACE}/reports:/app/reports ${pytestImageRun}"
                }
            }
            post {
                always {
                    // Only attempt to archive if the file was successfully written to the workspace
                    publishHTML([
                        allowMissing: true, // Prevents Jenkins from crashing if a massive compilation failure occurs
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports',
                        reportFiles: 'report.html',
                        reportName: 'Pytest API Report',
                        reportTitles: 'Petstore API Test Execution'
                    ])
                }
            }
        }

        stage('Deploy Performance Infrastructure (K8s)') {
            steps {
                script {
                    // Reconstruct the exact image tag built in Build #26
                    def locustImageName = "${DOCKER_REGISTRY}/petstore-locust:${env.BUILD_NUMBER}"

                    echo "Applying Kubernetes manifests..."
                    sh "kubectl apply -f infrastructure/k8s/locust.yaml"

                    // Fix: Pass the actual variable name, not an empty or misspelled reference
                    sh "kubectl set image deployment/locust-master locust-master=${locustImageName}"
                    sh "kubectl set image deployment/locust-worker locust-worker=${locustImageName}"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
